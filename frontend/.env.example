# Public frontend configuration. These values are safe to expose to the browser.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Supabase tester stack. Use only the public anon key here, never the service_role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional public JSE quote JSON endpoint/proxy. Browser-visible: do not put secrets here.
# Expected JSON can be an array of { symbol, price, changePercent } or { quotes: [...] }.
NEXT_PUBLIC_JSE_QUOTES_URL=
