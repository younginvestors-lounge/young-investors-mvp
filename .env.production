# AZURE PRODUCTION ENVIRONMENT
# Set these in Azure App Service → Configuration → Application settings

# Django
SECRET_KEY=your-production-secret-key-from-django-key-generator
DEBUG=False
ALLOWED_HOSTS=*.azurewebsites.net,younginvestors.co,www.younginvestors.co

# Database (Azure PostgreSQL Flexible Server)
DATABASE_URL=postgresql://yi_user:password@yi-server.postgres.database.azure.com:5432/young_investors?sslmode=require

# Email (SendGrid)
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
DEFAULT_FROM_EMAIL=noreply@younginvestors.co

# Frontend (Vercel)
FRONTEND_URL=https://younginvestors.vercel.app
CORS_ALLOWED_ORIGINS=https://younginvestors.vercel.app

# Security
CSRF_TRUSTED_ORIGINS=https://younginvestors.vercel.app,https://younginvestors.co,https://www.younginvestors.co

# Azure Storage (for media files if needed later)
# AZURE_STORAGE_ACCOUNT_NAME=yistorage
# AZURE_STORAGE_ACCOUNT_KEY=your-key-here
