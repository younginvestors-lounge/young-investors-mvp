# Django
SECRET_KEY=replace-with-a-strong-random-secret-at-least-32-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Supabase Postgres)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-password
DB_HOST=your-supabase-host.supabase.co
DB_PORT=5432

# Email
SENDGRID_API_KEY=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@younginvestors.co
# Local DEBUG default stores emails in .local-emails/ instead of printing tokens to logs.
EMAIL_BACKEND=django.core.mail.backends.filebased.EmailBackend
EMAIL_FILE_PATH=.local-emails

# Frontend
# Must be the public app URL in deployed environments. Do not leave localhost for testers.
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# JWT
JWT_SECRET_KEY=replace-with-a-strong-random-jwt-secret
